@page "/eventsettings"
@using EHive.Core.Library.Contracts.Events
@inherits EventSettingsBase

@if (!Loading)
{

    <MudCard>
        <MudCardContent>
            <MudCard Outlined="true" Class="form-card-body">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Configurações de Eventos</MudText>
                </MudCardHeader>
                <MudTable Items="@EventsConfigs" T="EventConfigDto" Hover="true" Outlined="true" Dense="true" RowClassFunc="RowClassSelector" SelectedItemChanged="SelectEvent">
                    <HeaderContent>
                        <MudTh>Chave</MudTh>
                        <MudTh>Origem</MudTh>
                        <MudTh>Nome</MudTh>
                        <MudTh>Persistente</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Key">@context.Key</MudTd>
                        <MudTd DataLabel="Origin">@context.Origin</MudTd>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="IsPersistence">@(context.IsPersistent ? "Sim" : "Não")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </MudCard>
        </MudCardContent>
    </MudCard>

    @if (SelectedConfig != null)
    {
        <MudCard Outlined="true" Class="form-card-body">
            <MudCardHeader>
                <MudStack>
                    <MudText Typo="Typo.h6">Configuração</MudText>
                </MudStack>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">Origem</MudText>
                        <MudText>@SelectedConfig.Origin</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">Evento</MudText>
                        <MudText>@SelectedConfig.Key</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Nome" @bind-Value="@SelectedConfig.Name" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Descrição" @bind-Value="@SelectedConfig.Description" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch Label="Persistente" @bind-Value="@SelectedConfig.IsPersistent" />
                    </MudItem>
                    <MudTable Items="@SelectedConfig.Fields" T="EventConfigFieldsDto" Hover="true" Outlined="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Campo</MudTh>
                            <MudTh>Valor</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Campo">@context.Key</MudTd>
                            <MudTd DataLabel="Valor">@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudGrid>
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" Variant="MudBlazor.Variant.Filled" OnClick="@SaveConfig">Salvar</MudButton>
                <MudPopover Open="@ShowMessage" Fixed="true" Class="px-4 pt-4">
                    <div class="d-flex flex-column">
                        <MudText>@Message</MudText>
                        <MudButton OnClick="@(() => @ShowMessage = false)" Class="ml-auto mr-n3 mb-1" Color="Color.Error">Close</MudButton>
                    </div>
                </MudPopover>
            </MudCardActions>
        </MudCard>
    }
}
else
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
}
