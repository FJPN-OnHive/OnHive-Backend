@page "/events"
@using OnHive.Core.Library.Contracts.Events
@using OnHive.Core.Library.Contracts.Users
@inherits EventsBase

@if (!Loading)
{
    <MudCard>
        <MudCardContent>
            <MudCard Outlined="true" Class="form-card-body">
                <MudCardHeader>
                    <MudStack>
                        <MudText Typo="Typo.h6">Eventos</MudText>
                        <MudSpacer />
                        <MudItem xs="12">
                            <MudDateRangePicker PickerVariant="@PickerVariant.Dialog" @bind-DateRange="@DateFilter" Margin="Margin.Dense" Label="Período" @onchange="LoadEvents" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect FullWidth="true" MultiSelectionTextFunc="@((selected) => GetUserSelectionText(selected))" MultiSelection="true" @bind-SelectedValues="SelectedUsers" T="UserDto" Label="Usuários" AdornmentIcon="@Icons.Material.Filled.Search" AnchorOrigin="Origin.BottomCenter">
                                @foreach (var user in Users)
                                {
                                    <MudSelectItem T="UserDto" Value="@user">@user.MainEmail</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudSelect FullWidth="true" MultiSelectionTextFunc="@((selected) => GetKeySelectionText(selected))" MultiSelection="true" @bind-SelectedValues="SelectedKeys" T="string" Label="Chaves" AdornmentIcon="@Icons.Material.Filled.Search" AnchorOrigin="Origin.BottomCenter">
                                @foreach (var key in Keys)
                                {
                                    <MudSelectItem T="string" Value="@key">@key</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudSelect FullWidth="true" MultiSelectionTextFunc="@((selected) => GetOriginSelectionText(selected))" MultiSelection="true" @bind-SelectedValues="SelectedOrigins" T="string" Label="Origens" AdornmentIcon="@Icons.Material.Filled.Search" AnchorOrigin="Origin.BottomCenter">
                                @foreach (var origin in Origins)
                                {
                                    <MudSelectItem T="string" Value="@origin">@origin</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Icon="@Icons.Material.Filled.Search" OnClick="@(() => LoadEvents())">Buscar</MudButton>
                        </MudItem>
                    </MudStack>
                </MudCardHeader>
                @if (!LoadingList)
                {
                    <MudTable Items="@Events" T="EventResumeDto" Hover="true" Outlined="true" Dense="true" RowClassFunc="RowClassSelector" SelectedItemChanged="SelectEvent">
                        <HeaderContent>
                            <MudTh>Data</MudTh>
                            <MudTh>Origem</MudTh>
                            <MudTh>Evento</MudTh>
                            <MudTh>Mensagem</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Date">@context.Date.ToString("dd/MM/yyyy HH:mm:ss")</MudTd>
                            <MudTd DataLabel="Origin">@context.Origin</MudTd>
                            <MudTd DataLabel="Key">@context.Key</MudTd>
                            <MudTd DataLabel="Message">@context.Message</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
                }
            </MudCard>
            <MudCard Outlined="true" Class="form-card-body">

            </MudCard>
        </MudCardContent>
    </MudCard>
    <MudCard>
        @if (!LoadingSelected)
        {
            @if (SelectedEvent != null)
            {
                <MudCard Outlined="true" Class="form-card-body">
                    <MudCardHeader>
                        <MudStack>
                            <MudText Typo="Typo.h6">Evento</MudText>
                        </MudStack>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">Data</MudText>
                                <MudText>@SelectedEvent.Date.ToString("dd/MM/yyyy HH:mm:ss")</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">Origem</MudText>
                                <MudText>@SelectedEvent.Origin</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">Evento</MudText>
                                <MudText>@SelectedEvent.Key</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">Usuário</MudText>
                                <MudText>@(Users.FirstOrDefault(u => u.Id == SelectedEvent.Id)?.MainEmail ?? string.Empty)</MudText>
                            </MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.h6">Mensagem</MudText>
                                <MudText>@SelectedEvent.Message</MudText>
                            </MudItem>
                            <MudTable Items="@SelectedEvent.Fields" T="KeyValuePair<string, string>" Hover="true" Outlined="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Campo</MudTh>
                                    <MudTh>Valor</MudTh>                                    
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Campo">@context.Key</MudTd>
                                    <MudTd DataLabel="Valor">@context.Value</MudTd>                                    
                                </RowTemplate>
                            </MudTable>

                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            }          
        }
        else
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
        }
    </MudCard>
}
else
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
}


