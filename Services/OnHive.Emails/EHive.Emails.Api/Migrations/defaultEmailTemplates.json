  {
    "Code": "EMAIL_VALIDATION",
    "Name": "Email Validation Default Template",
    "Body": "<!DOCTYPE html><html>   <meta charset=\"utf-8\" />  <link rel=\"stylesheet\" href=\"globals.css\" />  <link rel=\"stylesheet\" href=\"styleguide.css\" />  <link rel=\"stylesheet\" href=\"style.css\" /><body>  <div class=\"email-page\">    <img class=\"logo\" alt=\"logo-ehive\" src=\"https://sebrades-site-assets.s3.amazonaws.com/logoonhive.png\" />    <div class=\"email-content\">      <div class=\"text-info\">        <h1>Olá, &NAME;</h1>      </div>      <div class=\"text-info\">        <p>Esse é seu código de verificação</p>      </div>      <div class=\"text-info\">        <h2> &CODE; </h2>      </div>      <div class=\"text-info\">        <p>Você deve confirmar sua inscrição e definir sua senha clicando no botão abaixo.</p>      </div>             <div class=\"btn\">          <a href=\"&LINK;\">Ir ao site</a>      </div>    </div>  </div></body></html><style>  .email-page {    display: flex;    flex-direction: column;    align-items: center;    position: relative;    width: 640px;    background-color: #e9ecef;    padding-bottom: 20px;     height: fit-content;   }  .email-page .logo {    width: 144px;    height: 44px;    margin-top: 25px;   }  .email-page .email-content {    width: 610px;    min-height: auto;    background-color: #ffffff;    border-radius: 32px;    box-shadow: 8px 8px 10px 0px rgba(0, 0, 0, 0.1);    margin-top: 15px;   }  .text-info {    display: flex;    justify-content: center;  }  .text-info h1 {    font-family: 'Inter-Bold', Helvetica;    font-weight: 700;    color: #E58625;    font-size: 24px;    letter-spacing: 0;    margin-top: 34px;  }  .text-info h2 {    position: relative;    font-family: 'Inter-Bold', Helvetica;    font-weight: 900;    color: #000000;    text-align: center;    letter-spacing: 0;    line-height: normal;  }  .text-info p {    font-family: 'Inter-Bold', Helvetica;    font-weight: 400;    color: #262626;    font-size: 16px;    letter-spacing: 0;    width: 490px;    text-align: center;    margin: 0px;  }  .btn {    display: flex;    justify-content: center;  }  .btn a {    padding: 16px 24px;    background-color: #F3BB19;    border-radius: 32px;    cursor: pointer;    color: #000000;    text-decoration: none;    font-family: \"Inter-Regular\", Helvetica;    font-weight: 400;    font-size: 16px;    margin: 30px;  }",
    "Subject": "E-Hive - Confirmação de Email"
  },
